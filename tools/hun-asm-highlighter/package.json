{
  "name": "hun-asm-highlighter",
  "icon": "hun_icon_128.png",
  "license": "MIT",
  "displayName": "Hun ARM64 한글 어셈블리 강조",
  "description": "훈(Hun) 프로젝트 전용 - 한글 니모닉과 섹션 매크로를 인식하는 문법 강조, Syntax highlighting for Hun ARM64 Assembly with Korean mnemonics, ARM64 registers, directives, labels and section macros.",
  "version": "2.2.2",
  "main": "src/extension.js",
  "activationEvents": [
    "onLanguage:hun-asm"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ViVaKR/Hun.git",
    "directory": "tools/hun-asm-highlighter"
  },
  "publisher": "buddham-hq",
  "author": {
    "name": "BM. KIM BUM JUN"
  },
  "keywords": [
    "assembly",
    "arm64",
    "aarch64",
    "llvm",
    "hun",
    "korean",
    "syntax-highlighting",
    "snippets"
  ],
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "contributes": {
    "languages": [
      {
        "id": "hun-asm",
        "aliases": [
          "Hun ARM64 Assembly",
          "hun-asm"
        ],
        "extensions": [
          ".S",
          ".s",
          ".inc",
          ".asm"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "hun-asm",
        "scopeName": "source.hun-asm",
        "path": "./syntaxes/hun-asm.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "hun-asm",
        "path": "./snippets/hun-asm.code-snippets"
      }
    ],
    "configuration": {
      "title": "Hun ASM Highlighter 설정",
      "properties": {
        "hun-asm.alignDataDirectives": {
          "type": "boolean",
          "default": true,
          "description": "데이터 섹션의 지시어(.asciz 등)를 세로로 칼같이 정렬할지 여부를 결정합니다. true(기본값) = 🔥 칼군무 모드 / false = 🔹 라벨 밀착 모드."
        }
      }
    }
  }
}
