{
  "name": "hun-asm-highlighter",
  "icon": "hun_icon_128.png",
  "license": "MIT",
  "displayName": "Hun ARM64 한글 어셈블리 강조",
  "description": "훈(Hun) 프로젝트 전용 - 한글 니모닉과 섹션 매크로를 인식하는 문법 강조, Syntax highlighting for Hun ARM64 Assembly with Korean mnemonics, ARM64 registers, directives, labels and section macros.",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ViVaKR/Hun.git",
    "directory": "tools/hun-asm-highlighter"
  },
  "publisher": "buddham-hq",
  "author": {
    "name": "BM. KIM BUM JUN"
  },
  "keywords": [
    "assembly",
    "arm64",
    "aarch64",
    "llvm",
    "hun",
    "korean",
    "syntax-highlighting"
  ],
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "hun-asm",
        "aliases": [
          "Hun ARM64 Assembly",
          "hun-asm"
        ],
        "extensions": [
          ".S",
          ".s",
          ".inc",
          ".asm"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "hun-asm",
        "scopeName": "source.hun-asm",
        "path": "./syntaxes/hun-asm.tmLanguage.json"
      }
    ]
  }
}
