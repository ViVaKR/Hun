{
  // 1. 주석(Comments) 기능 정의 구역
  // 유저가 코드창에서 단축키(예: Ctrl + /)를 눌렀을 때 자동으로 붙을 주석 모양을 정합니다.
  // 블록 주석 단축키를 누르면 "/*" 로 시작해서 "*/" 로 끝나게 묶어라.
  // "lineComment": "//", // 한 줄 주석은 무조건 "//" 로 시작하게 만들어라.
  "comments": {
    "lineComment": {
      "comment": "//"
    },
    "blockComment": ["/*", "*/"]
  },

  // 2. 괄호쌍(Brackets) 매칭 구역
  // 코드에서 괄호의 짝이 맞는지 VS Code가 감시하고, 괄호 안쪽 영역을 강조할 때 참고하는 기준입니다.
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],

  // "brackets": [
  //   ["[", "]"], // 대괄호 [ ] 의 시작과 끝을 한 쌍으로 묶어서 인식해라.
  //   ["(", ")"] // 소괄호 ( ) 의 시작과 끝을 한 쌍으로 묶어서 인식해라.
  // ],

  // 3. 자동 괄호 닫기(Auto Closing Pairs) 구역
  // 개발자가 열는 기호([, (, ")를 타이핑하는 순간, 닫는 기호(], ), ")를 오른쪽에 자동으로 만들어주는 자비로운 기능입니다.
  // 3. 자비로운 괄호/따옴표 자동 완성
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "'", "close": "'", "notIn": ["string", "comment"] },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "`", "close": "`", "notIn": ["string", "comment"] }
  ],
  "autoCloseBefore": ";:.,=}])>` \n\t",
  // "autoClosingPairs": [
  //   { "open": "[", "close": "]" }, // 개발자가 "["를 치면 오른쪽 뒤에 "]"를 자동으로 대령해라.
  //   { "open": "(", "close": ")" }, // 개발자가 "("를 치면 오른쪽 뒤에 ")"를 자동으로 대령해라.
  //   { "open": "\"", "close": "\"" } // 개발자가 큰따옴표("\"")를 치면 닫는 큰따옴표를 자동으로 대령해라.
  // ],

  // 4. 감싸기 기능(Surrounding Pairs) 구역
  // 코드 창에서 마우스로 특정 단어나 문장을 '블록 지정'한 상태에서 괄호나 따옴표 키를 누르면,
  // 그 글자를 지우지 않고 겉 표면을 대칭형 장갑처럼 앞뒤로 싹 감싸주는 기능입니다.
  // 4. 블록 지정 후 기호 누르면 앞뒤 장갑 감싸기
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["'", "'"],
    ["\"", "\""],
    ["`", "`"]
  ],

  // 5. 대형 코드 관리를 위한 접기 기능 (#region / #endregion)
  "folding": {
    "markers": {
      "start": "^\\s*//\\s*#?region\\b",
      "end": "^\\s*//\\s*#?endregion\\b"
    }
  },

  // "surroundingPairs": [
  //   ["[", "]"], // 글자 블록 잡고 "[" 누르면 [선택글자] 형태로 감싸라.
  //   ["(", ")"], // 글자 블록 잡고 "(" 누르면 (선택글자) 형태로 감싸라.
  //   ["\"", "\""] // 글자 블록 잡고 "\"" 누르면 "선택글자" 형태로 감싸라.
  // ],

  // 5. 단어 인식 패턴(Word Pattern) 구역
  // 마우스로 단어를 '더블 클릭'하여 선택하거나, 코드를 자동 완성(IntelliSense)할 때
  // 어디서부터 어디까지를 '하나의 독립된 단어'로 판정할지 결정하는 핵심 정규식 요새입니다.
  // "wordPattern": "[\\p{L}_.$][\\p{L}0-9_.$]*"
  // 5. 단어 인식 패턴(Word Pattern) 구역 (수정 버전!)
  // 역슬래시 이스케이프 문제를 원천 차단하고 온 우주의 문자(한글 포함)와
  // 특수기호(_, ., $)가 결합된 '모든 길이의 덩어리'를 하나의 단어로 인정합니다.
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([^\\`\\~\\!\\@\\#\\%\\^\\&\\*\\(\\)\\-\\=\\+\\[\\{\\]\\}\\\\\\|\\;\\:\\'\\\"\\,\\<\\>\\/\\?\\s]+)"

  // [해설]: 알파벳뿐만 아니라 온 우주의 언어(한글 포함: \p{L})와 _, ., $ 로 시작하고,
  // 그 뒤에는 숫자까지 포함된 모든 덩어리를 '끊어지지 않는 하나의 단어'로 취급해라!
  // (이 덕분에 '적재', '함수야:' 같은 한글 니모닉과 라벨이 쪼개지지 않고 깔끔하게 관리됩니다.)
}
