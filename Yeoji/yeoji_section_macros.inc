// =============================================================================
//  제목: ELF 베어메탈 전용 섹션 선언 매크로 모음
//  목적: aarch64-none-elf 타겟에 맞춤 정화
// =============================================================================

// -------------------------------------------------------------
// [코드 구역] .text
// 실제 기계어 명령어가 위치하는 순수 명령어 구역일세.
// -------------------------------------------------------------
.macro CODE_SECTION
    .section .text
.endmacro

// -------------------------------------------------------------
// [C-스타일 문자열 리터럴] .rodata
// printf나 uart_puts 포맷 스트링 등 읽기 전용 문자열 상수 구역
// -------------------------------------------------------------
.macro CSTRING_SECTION
    .section .rodata
.endmacro

// -------------------------------------------------------------
// [읽기전용 상수 데이터 및 포인터 테이블] .rodata
// 동적 재배치가 필요 없는 함수 포인터 테이블(command_table) 최적의 공간!
// -------------------------------------------------------------
.macro CONST_DATA_SECTION
    .section .rodata
.endmacro

// -------------------------------------------------------------
// [초기화된 변수] .data
// 선언과 동시에 값이 존재하며 실행 중 수정 가능한 전역 변수 영역
// -------------------------------------------------------------
.macro DATA_SECTION
    .section .data
.endmacro

// -------------------------------------------------------------
// [0으로 초기화된 변수] .bss
// 초기값이 없거나 0인 변수 구역
// -------------------------------------------------------------
.macro BSS_SECTION
    .section .bss
.endmacro

// (나머지 CONST_SECTION 등 자네가 쓰던 매크로들도 전부 뒤의 복잡한 인자들을 떼어내고 
//  .text 나 .rodata, .data, .bss 중 하나로 콤팩트하게 매핑해 버리면 끝난다네!)
