# ==========================================
# 🌌 [훈 제국] 프로젝트 통합 .gitignore
# ==========================================

# 1. 🛠️ CMake & 빌드 산출물
# ------------------------------------------
/build/
/CMakeUserPresets.json
/.cmake/

CMakeCache.txt
CMakeFiles/
/build/Makefile
cmake_install.cmake
*.d
*.dia
*.LinkFileList

# 2. 🍏 Apple Xcode 관련
# ------------------------------------------
.DS_Store
._*
.AppleDouble
.LSOverride
DerivedData/
*.xcuserstate
xcuserdata/
*.xccheckout
*.moved-aside
*.xcworkspace/
*.xcodeproj/
*.dSYM/

# 3. 🦀 Rust (Cargo) 관련
# ------------------------------------------
/hun_apps/target/
/hun_apps/**/target/
/hun_apps/Cargo.lock

# 4. 💻 JetBrains
# ------------------------------------------
/.idea/
*.iws
*.iml

# 5. 🔷 VSCode (설정 일부는 공유하고 싶을 수 있으니 선택적으로)
# ------------------------------------------
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# 6. 📦 실행 파일 및 백업
# ------------------------------------------
*.o
*.a
*.out

build/
build-xcode/

tools/
target/